<section class="mourao-section mourao-section--spacious mourao-bestsellers">
  <div class="page-width">
    <div class="mourao-panel">
      <div class="mourao-section-header">
        {% if section.settings.eyebrow != blank %}
          <p class="mourao-eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}
        <h2 class="mourao-section-title">{{ section.settings.title }}</h2>
        <p class="mourao-section-copy">Dit zijn de favorieten waar klanten vaak mee starten: vertrouwde texturen, milde formules en producten die meteen logisch voelen.</p>
      </div>

      <div class="mourao-product-list">
        {% for block in section.blocks %}
          <div {{ block.shopify_attributes }}>
          {% render 'mourao-product-card',
            title: block.settings.title,
            description: block.settings.description,
            button_label: block.settings.button_label,
            button_link: block.settings.button_link,
            eyebrow: block.settings.badge,
            meta: block.settings.meta,
            image_key: block.settings.image_key,
            accent_index: forloop.index
          %}
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Mourao bestsellers",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Best bekeken"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Waar mensen mee beginnen"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "text",
          "id": "image_key",
          "label": "Image key",
          "default": "tallowcreme"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Tallowcrème"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Korte bestsellerbeschrijving."
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge",
          "default": "Meest gekozen"
        },
        {
          "type": "text",
          "id": "meta",
          "label": "Meta",
          "default": "Vanaf €24"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Bekijk favoriet"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Mourao bestsellers"
    }
  ]
}
{% endschema %}

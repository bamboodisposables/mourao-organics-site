<section id="reviews" class="mourao-section mourao-section--spacious">
  <div class="page-width">
    <div class="mourao-section-header">
      <p class="mourao-eyebrow">Reviews</p>
      <h2 class="mourao-section-title">{{ section.settings.title }}</h2>
      <p class="mourao-section-copy">Voorbeeldreacties die de rustige, toegankelijke richting van MOURÃO Organics laten voelen.</p>
    </div>

    <div class="mourao-grid mourao-grid--reviews">
      {% for block in section.blocks %}
        <div {{ block.shopify_attributes }}>
          {% render 'mourao-review-card',
            author: block.settings.author,
            text: block.settings.text,
            accent_index: forloop.index
          %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Mourao reviews",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Geliefd door bewuste huidverzorgers"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "text",
          "id": "author",
          "label": "Author",
          "default": "Sanne"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Placeholder reviewtekst."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Mourao reviews"
    }
  ]
}
{% endschema %}

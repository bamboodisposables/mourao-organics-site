<section class="mourao-section mourao-section--spacious mourao-hero">
  <div class="page-width">
    <div class="mourao-hero__layout">
      <div class="mourao-hero__content mourao-reveal" style="--animation-order: 1;">
        {% if section.settings.eyebrow != blank %}
          <p class="mourao-eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}

        <h1 class="mourao-heading">{{ section.settings.heading }}</h1>
        <p class="mourao-hero__text">{{ section.settings.subheading }}</p>

        <div class="mourao-hero__actions">
          {% if section.settings.button_label != blank %}
            <a class="mourao-button" href="{{ section.settings.button_link | default: routes.all_products_collection_url }}">
              {{ section.settings.button_label }}
            </a>
          {% endif %}

          {% if section.settings.secondary_label != blank %}
            <a class="mourao-inline-link" href="{{ section.settings.secondary_link | default: routes.root_url }}#verhaal">
              {{ section.settings.secondary_label }}
            </a>
          {% endif %}
        </div>

        <div class="mourao-chip-row">
          {% if section.settings.highlight_one != blank %}
            <span class="mourao-chip">{{ section.settings.highlight_one }}</span>
          {% endif %}
          {% if section.settings.highlight_two != blank %}
            <span class="mourao-chip">{{ section.settings.highlight_two }}</span>
          {% endif %}
          {% if section.settings.highlight_three != blank %}
            <span class="mourao-chip">{{ section.settings.highlight_three }}</span>
          {% endif %}
        </div>
      </div>

      <div class="mourao-hero__visual mourao-reveal" style="--animation-order: 2;" aria-hidden="true">
        <div class="mourao-hero__frame">
          <div class="mourao-hero__product-visual">
            <div class="mourao-hero__product-glow"></div>
            <img
              class="mourao-hero__logo"
              src="{{ 'mourao-logo.jpg' | asset_url }}"
              alt="MOURÃO Organics logo"
              width="900"
              height="900"
              loading="eager"
              fetchpriority="high"
            >
          </div>

          <div class="mourao-hero__note">
            <p class="mourao-eyebrow">Home made</p>
            <p class="mourao-hero__note-title">Pure verzorging die je dagelijks wilt blijven gebruiken.</p>
            <ul class="mourao-bullet-list">
              <li>Gemaakt in kleine batches met natuurlijke ingrediënten</li>
              <li>Zachte formules voor droge, gevoelige of snel reagerende huid</li>
              <li>Geen overdaad, maar producten die rustig en betrouwbaar voelen</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Mourao hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "MOURÃO Organics"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Eerlijke verzorging voor een huid die rust zoekt"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Handgemaakte skincare met pure ingrediënten, zachte texturen en een aardse, toegankelijke benadering van dagelijkse verzorging."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Bekijk collectie"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary link label",
      "default": "Lees ons verhaal"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary link"
    },
    {
      "type": "text",
      "id": "highlight_one",
      "label": "Highlight 1",
      "default": "Handgemaakt in Nederland"
    },
    {
      "type": "text",
      "id": "highlight_two",
      "label": "Highlight 2",
      "default": "Gratis verzending vanaf €30"
    },
    {
      "type": "text",
      "id": "highlight_three",
      "label": "Highlight 3",
      "default": "30 dagen rustig proberen"
    }
  ],
  "presets": [
    {
      "name": "Mourao hero"
    }
  ]
}
{% endschema %}

<section class="mourao-section">
  <div class="page-width">
    <div class="mourao-trust-bar">
      {% for block in section.blocks %}
        <div class="mourao-trust-bar__item mourao-reveal" style="--animation-order: {{ forloop.index }};" {{ block.shopify_attributes }}>
          {{ block.settings.text }}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Mourao trust bar",
  "max_blocks": 4,
  "blocks": [
    {
      "type": "claim",
      "name": "Claim",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "100% natuurlijke ingrediënten"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Mourao trust bar",
      "blocks": [
        {
          "type": "claim"
        },
        {
          "type": "claim"
        },
        {
          "type": "claim"
        },
        {
          "type": "claim"
        }
      ]
    }
  ]
}
{% endschema %}

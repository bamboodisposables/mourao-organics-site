{% liquid
  assign image_key = section.settings.image_key | default: 'tallowcreme'
  assign hero_asset = 'mourao-product-' | append: image_key | append: '-hero.jpg'
  assign thumb_one_asset = 'mourao-product-' | append: image_key | append: '-thumb-1.jpg'
  assign thumb_two_asset = 'mourao-product-' | append: image_key | append: '-thumb-2.jpg'
  assign thumb_three_asset = 'mourao-product-' | append: image_key | append: '-thumb-3.jpg'
  assign thumb_four_asset = 'mourao-product-' | append: image_key | append: '-thumb-4.jpg'
  assign has_related = false
  for block in section.blocks
    if block.type == 'related'
      assign has_related = true
    endif
  endfor
%}

<section class="mourao-section mourao-section--spacious mourao-product-page">
  <div class="page-width">
    <div class="mourao-product-layout">
      <div class="mourao-gallery mourao-reveal" style="--animation-order: 1;">
        <div class="mourao-gallery__main">
          <div class="mourao-gallery__hero" style="--mourao-gallery-image: url({{ hero_asset | asset_url }});">
            <div class="mourao-gallery__hero-glow"></div>
          </div>
          <p class="mourao-gallery__caption">{{ section.settings.gallery_caption }}</p>
        </div>

        <div class="mourao-gallery__thumbs" aria-hidden="true">
          <span class="mourao-gallery__thumb" style="--mourao-thumb-image: url({{ thumb_one_asset | asset_url }});">Original</span>
          <span class="mourao-gallery__thumb" style="--mourao-thumb-image: url({{ thumb_two_asset | asset_url }});">Calming</span>
          <span class="mourao-gallery__thumb" style="--mourao-thumb-image: url({{ thumb_three_asset | asset_url }});">Sensitive</span>
          <span class="mourao-gallery__thumb" style="--mourao-thumb-image: url({{ thumb_four_asset | asset_url }});">Starter size</span>
        </div>

        {% if has_related %}
          <div class="mourao-related-panel mourao-reveal" style="--animation-order: 2;">
            <div class="mourao-related-panel__header">
              <p class="mourao-eyebrow">{{ section.settings.related_eyebrow }}</p>
              <h2 class="mourao-related-panel__title">{{ section.settings.related_title }}</h2>
              <p class="mourao-related-panel__text">{{ section.settings.related_text }}</p>
            </div>

            <div class="mourao-related-list">
              {% for block in section.blocks %}
                {% if block.type == 'related' %}
                  {% assign related_asset = 'mourao-product-' | append: block.settings.image_key | append: '-card.jpg' %}
                  <a class="mourao-related-card" href="{{ block.settings.link | default: routes.all_products_collection_url }}" {{ block.shopify_attributes }}>
                    <span class="mourao-related-card__media" style="--mourao-related-image: url({{ related_asset | asset_url }});" aria-hidden="true"></span>
                    <span class="mourao-related-card__body">
                      <strong>{{ block.settings.title }}</strong>
                      <span>{{ block.settings.text }}</span>
                    </span>
                    <span class="mourao-related-card__meta">{{ block.settings.meta }}</span>
                  </a>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        {% endif %}
      </div>

      <div class="mourao-product-box mourao-reveal" style="--animation-order: 2;">
        <div class="mourao-rating">
          <span class="mourao-stars" aria-hidden="true">★★★★★</span>
          <span>{{ section.settings.rating_text }}</span>
        </div>

        <p class="mourao-eyebrow">{{ section.settings.eyebrow }}</p>
        <h1 class="mourao-product-title">{{ section.settings.title }}</h1>
        <p class="mourao-product-lead">{{ section.settings.subtitle }}</p>

        <ul class="mourao-bullet-list mourao-bullet-list--compact">
          {% for block in section.blocks %}
            {% if block.type == 'benefit' %}
              <li {{ block.shopify_attributes }}>{{ block.settings.text }}</li>
            {% endif %}
          {% endfor %}
        </ul>

        <div class="mourao-option-group">
          <p class="mourao-option-group__label">Kies je formule</p>
          <div class="mourao-option-list">
            {% for block in section.blocks %}
              {% if block.type == 'formula' %}
                <div class="mourao-option" {{ block.shopify_attributes }}>
                  <strong>{{ block.settings.title }}</strong>
                  <span>{{ block.settings.text }}</span>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>

        <div class="mourao-option-group">
          <p class="mourao-option-group__label">Kies je formaat</p>
          <div class="mourao-option-list mourao-option-list--sizes">
            {% for block in section.blocks %}
              {% if block.type == 'size' %}
                <div class="mourao-option mourao-option--size" {{ block.shopify_attributes }}>
                  <strong>{{ block.settings.title }}</strong>
                  <span>{{ block.settings.text }}</span>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>

        <a class="mourao-button mourao-button--full" href="{{ section.settings.button_link | default: routes.all_products_collection_url }}">
          {{ section.settings.button_label }}
        </a>

        <div class="mourao-product-notes">
          <p>{{ section.settings.shipping_note }}</p>
          <p>{{ section.settings.stock_note }}</p>
        </div>
      </div>
    </div>

    <div class="mourao-proof-strip">
      <div class="mourao-proof-card">
        <strong>{{ section.settings.proof_one_value }}</strong>
        <span>{{ section.settings.proof_one_label }}</span>
      </div>
      <div class="mourao-proof-card">
        <strong>{{ section.settings.proof_two_value }}</strong>
        <span>{{ section.settings.proof_two_label }}</span>
      </div>
      <div class="mourao-proof-card">
        <strong>{{ section.settings.proof_three_value }}</strong>
        <span>{{ section.settings.proof_three_label }}</span>
      </div>
    </div>

    <div class="mourao-section-header">
      <p class="mourao-eyebrow">{{ section.settings.details_eyebrow }}</p>
      <h2 class="mourao-section-title">{{ section.settings.details_title }}</h2>
      <p class="mourao-section-copy">{{ section.settings.details_copy }}</p>
    </div>

    <div class="mourao-detail-grid">
      <article class="mourao-detail-card">
        <h3>{{ section.settings.detail_one_title }}</h3>
        <p>{{ section.settings.detail_one_text }}</p>
      </article>
      <article class="mourao-detail-card">
        <h3>{{ section.settings.detail_two_title }}</h3>
        <p>{{ section.settings.detail_two_text }}</p>
      </article>
      <article class="mourao-detail-card">
        <h3>{{ section.settings.detail_three_title }}</h3>
        <p>{{ section.settings.detail_three_text }}</p>
      </article>
      <article class="mourao-detail-card">
        <h3>{{ section.settings.detail_four_title }}</h3>
        <p>{{ section.settings.detail_four_text }}</p>
      </article>
    </div>

    <div class="mourao-section-header" id="faq">
      <p class="mourao-eyebrow">{{ section.settings.faq_eyebrow }}</p>
      <h2 class="mourao-section-title">{{ section.settings.faq_title }}</h2>
    </div>

    {% assign first_faq_open = true %}
    <div class="mourao-faq-list">
      {% for block in section.blocks %}
        {% if block.type == 'faq' %}
          <details class="mourao-faq-item" {% if first_faq_open %}open{% endif %} {{ block.shopify_attributes }}>
            <summary>{{ block.settings.title }}</summary>
            <div class="mourao-faq-item__content">
              <p>{{ block.settings.text }}</p>
            </div>
          </details>
          {% assign first_faq_open = false %}
        {% endif %}
      {% endfor %}
    </div>

    <div class="mourao-section-header">
      <p class="mourao-eyebrow">{{ section.settings.reviews_eyebrow }}</p>
      <h2 class="mourao-section-title">{{ section.settings.reviews_title }}</h2>
      <p class="mourao-section-copy">{{ section.settings.reviews_copy }}</p>
    </div>

    <div class="mourao-grid mourao-grid--reviews">
      {% for block in section.blocks %}
        {% if block.type == 'testimonial' %}
          {% render 'mourao-review-card',
            author: block.settings.author,
            context: block.settings.context,
            text: block.settings.text,
            accent_index: forloop.index
          %}
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>


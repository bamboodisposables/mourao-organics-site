<section id="verhaal" class="mourao-section mourao-section--spacious mourao-story-section">
  <div class="page-width">
    <div class="mourao-story">
      <div class="mourao-section-header mourao-reveal" style="--animation-order: 1;">
        {% if section.settings.eyebrow != blank %}
          <p class="mourao-eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}
        <h2 class="mourao-section-title">{{ section.settings.title }}</h2>
        <p class="mourao-text">{{ section.settings.text }}</p>
      </div>

      <div class="mourao-story-card mourao-reveal" style="--animation-order: 2;">
        <p class="mourao-story-card__lead">Niet in massa gemaakt. Gewoon met de hand, stap voor stap.</p>
        <h3 class="mourao-story-card__title">Van keukenritme naar dagelijkse routine</h3>
        <p class="mourao-story-card__text">MOURÃO begon vanuit de behoefte aan verzorging die kalm aanvoelt: zuivere ingrediënten, zachte texturen en geen overbodige claims. Wat goed werkte voor thuisgebruik, groeide uit tot een kleine collectie voor mensen die dezelfde rust zoeken.</p>

        <div class="mourao-story-card__list">
          {% if section.settings.value_one != blank %}
            <span>{{ section.settings.value_one }}</span>
          {% endif %}
          {% if section.settings.value_two != blank %}
            <span>{{ section.settings.value_two }}</span>
          {% endif %}
          {% if section.settings.value_three != blank %}
            <span>{{ section.settings.value_three }}</span>
          {% endif %}
        </div>

        <p class="mourao-story-card__footnote">Elke batch begint klein, zodat textuur, geur en gevoel dichtbij blijven. Dat merk je in hoe makkelijk de producten in je routine passen.</p>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Mourao brand story",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Ons verhaal"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Home made, rustig opgebouwd"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "MOURÃO Organics maakt verzorgingsproducten met pure ingrediënten en eenvoudige formules. Geen overbodige toevoegingen, maar zachte producten die passen in je dagelijkse routine."
    },
    {
      "type": "text",
      "id": "value_one",
      "label": "Value 1",
      "default": "Kleine batches"
    },
    {
      "type": "text",
      "id": "value_two",
      "label": "Value 2",
      "default": "Functionele ingrediënten"
    },
    {
      "type": "text",
      "id": "value_three",
      "label": "Value 3",
      "default": "Zachte dagelijkse verzorging"
    }
  ],
  "presets": [
    {
      "name": "Mourao brand story"
    }
  ]
}
{% endschema %}

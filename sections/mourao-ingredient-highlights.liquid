<section class="mourao-section mourao-section--spacious">
  <div class="page-width">
    <div class="mourao-section-header">
      {% if section.settings.eyebrow != blank %}
        <p class="mourao-eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h2 class="mourao-section-title">{{ section.settings.title }}</h2>
    </div>

    <div class="mourao-grid mourao-grid--ingredients">
      {% for block in section.blocks %}
        <article class="mourao-ingredient-card mourao-reveal" style="--animation-order: {{ forloop.index }};" {{ block.shopify_attributes }}>
          <div class="mourao-ingredient-card__icon" aria-hidden="true"></div>
          <h3 class="mourao-ingredient-card__title">{{ block.settings.title }}</h3>
          <p class="mourao-ingredient-card__text">{{ block.settings.text }}</p>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Mourao ingredient highlights",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Wat erin zit"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Ingrediënten die je huid begrijpen"
    }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Shea butter"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Korte beschrijving van het ingrediënt."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Mourao ingredient highlights"
    }
  ]
}
{% endschema %}

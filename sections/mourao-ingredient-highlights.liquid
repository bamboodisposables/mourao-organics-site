<section id="ingredienten" class="mourao-section mourao-section--spacious mourao-ingredient-section">
  <div class="page-width">
    <div class="mourao-section-header">
      {% if section.settings.eyebrow != blank %}
        <p class="mourao-eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h2 class="mourao-section-title">{{ section.settings.title }}</h2>
    </div>

    <div class="mourao-ingredient-list">
      {% for block in section.blocks %}
        {% assign ingredient_variant = forloop.index | modulo: 4 | plus: 1 %}
        <details class="mourao-ingredient-row mourao-reveal" style="--animation-order: {{ forloop.index }};" {{ block.shopify_attributes }}>
          <summary class="mourao-ingredient-row__summary">
            <div class="mourao-ingredient-row__media mourao-ingredient-row__media--{{ ingredient_variant }}" aria-hidden="true"></div>
            <h3 class="mourao-ingredient-row__title">{{ block.settings.title }}</h3>
            <span class="mourao-ingredient-row__toggle" aria-hidden="true"></span>
          </summary>
          <div class="mourao-ingredient-row__content">
            <p class="mourao-ingredient-row__text">{{ block.settings.text }}</p>
          </div>
        </details>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Mourao ingredient highlights",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Wat erin zit"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Ingrediënten die je huid begrijpen"
    }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Shea butter"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Korte beschrijving van het ingrediënt."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Mourao ingredient highlights"
    }
  ]
}
{% endschema %}
